<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvOrganType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Kidney"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳ Pending"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_status_badge"
                android:padding="6dp" />

        </LinearLayout>

        <!-- Recipient Information -->
        <TextView
            android:id="@+id/tvRecipientName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="John Doe"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <!-- Quick Info Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvBloodType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Blood: O+"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvUrgency"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Urgency: High"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Hospital Information -->
        <TextView
            android:id="@+id/tvHospitalName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apollo Hospital, Mumbai"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <!-- Additional Information -->
        <TextView
            android:id="@+id/tvAdditionalInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aadhaar: 123456789012"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <!-- Treating Doctor -->
        <TextView
            android:id="@+id/tvTreatingDoctor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Doctor: Dr. Smith"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <!-- Request Date -->
        <TextView
            android:id="@+id/tvRequestDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Requested: 31/03/2026"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:gravity="end"
            android:layout_marginBottom="8dp" />

        <!-- Donor Match Button (for hospital users only) -->
        <Button
            android:id="@+id/btnFindDonors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎯 View Top 10 Compatible Donors"
            android:textSize="14sp"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:visibility="gone"
            style="@style/Widget.AppCompat.Button.Colored" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
