<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@color/primary"
            android:padding="20dp">

            <ImageView
                android:id="@+id/hospitalIcon"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_hospital"
                app:tint="@color/white"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hospital_registration"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_below="@id/hospitalIcon"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hospital_reg_subtitle"
                android:textColor="@color/white"
                android:layout_below="@id/hospitalIcon"
                android:layout_marginTop="40dp"/>
        </RelativeLayout>

        <!-- Card Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section 1: Basic Hospital Information -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="@string/section_basic_hospital_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp"/>

                    <EditText
                        android:id="@+id/etHospitalName"
                        android:hint="@string/hint_hospital_name"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_hospital"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etGovRegNumber"
                        android:hint="@string/hint_gov_reg_number"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_id_card"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etHospitalId"
                        android:hint="@string/hint_hospital_id"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_id_card"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:focusable="false"
                        android:clickable="false"
                        android:text="HOS-XXXX-XXXX"/>

                    <EditText
                        android:id="@+id/etEstYear"
                        android:hint="@string/hint_est_year"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_calendar"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:inputType="number"
                        android:maxLength="4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <Spinner
                        android:id="@+id/spinnerHospitalType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_spinner"
                        android:layout_marginBottom="8dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section 2: Contact Information -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="@string/section_contact_info"
                        android:textStyle="bold"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp"/>

                    <EditText
                        android:id="@+id/etOfficialEmail"
                        android:hint="@string/hint_official_email"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_email"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:inputType="textEmailAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etContactNumber"
                        android:hint="@string/hint_contact_number"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_phone"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:inputType="phone"
                        android:maxLength="15"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etEmergencyContact"
                        android:hint="@string/hint_emergency_contact"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_emergency"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:inputType="phone"
                        android:maxLength="15"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etWebsiteUrl"
                        android:hint="@string/hint_website_url"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_web"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:inputType="textUri"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section 3: Address -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_address"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp"/>

                    <EditText
                        android:id="@+id/etStreet"
                        android:hint="@string/hint_street"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_home"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etCity"
                        android:hint="@string/hint_city"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_city"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etState"
                        android:hint="Enter state"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_location"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etPincode"
                        android:hint="Enter pincode"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_location"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:inputType="number"
                        android:maxLength="6"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etLandmark"
                        android:hint="@string/hint_landmark"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_landmark"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section 4: Location Data -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_location_data"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <EditText
                            android:id="@+id/etLatitude"
                            android:hint="@string/hint_latitude"
                            android:background="@drawable/bg_input_field"
                            android:drawableStart="@drawable/ic_location"
                            android:drawablePadding="12dp"
                            android:padding="12dp"
                            android:inputType="numberDecimal"
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"/>

                        <ImageButton
                            android:id="@+id/btnGetLocation"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_button_outline"
                            android:src="@drawable/ic_location"
                            app:tint="@color/primary"/>

                    </LinearLayout>

                    <EditText
                        android:id="@+id/etLongitude"
                        android:hint="@string/hint_longitude"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_location"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:inputType="numberDecimal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/location_note"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section 5: Facilities Available -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="@string/section_facilities"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp"
                        android:layout_height="20dp"
                        android:layout_width="match_parent"/>

                    <CheckBox
                        android:id="@+id/cbOrganTransplant"
                        android:text="@string/facility_organ_transplant"
                        android:layout_marginBottom="8dp"
                        android:layout_height="20dp"
                        android:layout_width="match_parent"/>

                    <CheckBox
                        android:id="@+id/cbICU"
                        android:text="@string/facility_icu"
                        android:layout_marginBottom="8dp"
                        android:layout_height="20dp"
                        android:layout_width="match_parent"/>

                    <CheckBox
                        android:id="@+id/cbEmergency"
                        android:text="@string/facility_emergency"
                        android:layout_marginBottom="8dp"
                        android:layout_height="20dp"
                        android:layout_width="match_parent"/>

                    <CheckBox
                        android:id="@+id/cbOrganStorage"
                        android:text="@string/facility_organ_storage"
                        android:layout_marginBottom="8dp"
                        android:layout_height="20dp"
                        android:layout_width="match_parent"/>

                    <CheckBox
                        android:id="@+id/cbLaboratory"
                        android:text="@string/facility_laboratory"
                        android:layout_marginBottom="8dp"
                        android:layout_height="20dp"
                        android:layout_width="match_parent"/>

                    <CheckBox
                        android:id="@+id/cbAmbulance"
                        android:text="@string/facility_ambulance"
                        android:layout_height="20dp"
                        android:layout_width="match_parent"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section 6: Hospital Authority Details -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="@string/section_authority"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/etAuthorityName"
                        android:hint="@string/hint_authority_name"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_doctor"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etAuthorityContact"
                        android:hint="@string/hint_authority_contact"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_phone"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:inputType="phone"
                        android:maxLength="15"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etAuthorityEmail"
                        android:hint="@string/hint_authority_email"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_email"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:inputType="textEmailAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section 7: Verification -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_verification"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/upload_documents"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <Button
                            android:id="@+id/btnUploadLicense"
                            android:text="@string/btn_upload_license"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_button_outline"
                            android:textColor="@color/primary"
                            style="?android:attr/buttonBarButtonStyle"/>

                        <Button
                            android:id="@+id/btnUploadCertificate"
                            android:text="@string/btn_upload_certificate"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_button_outline"
                            android:textColor="@color/primary"
                            style="?android:attr/buttonBarButtonStyle"/>

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnUploadIdentity"
                        android:text="@string/btn_upload_identity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_button_outline"
                        android:textColor="@color/primary"
                        style="?android:attr/buttonBarButtonStyle"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- System Status Fields -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_system_status"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:text="@string/label_approval_status"
                        android:textStyle="bold"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvApprovalStatus"
                        android:text="@string/status_pending"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_input_field"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:text="@string/label_verification_status"
                        android:textStyle="bold"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvVerificationStatus"
                        android:text="@string/status_pending"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_input_field"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Hospital Terms and Conditions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/checkboxHospitalTermsConditions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary"
                    android:scaleX="1.2"
                    android:scaleY="1.2" />

                <TextView
                    android:id="@+id/tvHospitalTermsConditions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="I accept the Hospital Terms and Conditions"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="normal" />

            </LinearLayout>

            <!-- Action Buttons -->
            <Button
                android:id="@+id/btnRegisterHospital"
                android:text="@string/btn_register_hospital"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_register"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnReset"
                    android:text="@string/btn_reset"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_button_outline"
                    android:textColor="@color/primary"
                    style="?android:attr/buttonBarButtonStyle"/>

                <Button
                    android:id="@+id/btnBack"
                    android:text="@string/btn_back"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_button_outline"
                    android:textColor="@color/primary"
                    style="?android:attr/buttonBarButtonStyle"/>

            </LinearLayout>

            <!-- Footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/hospital_reg_footer"
                android:textSize="12sp"
                android:textColor="@color/footer_text"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
