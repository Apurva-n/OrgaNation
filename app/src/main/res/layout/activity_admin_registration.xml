<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@color/primary"
            android:padding="20dp">

            <ImageView
                android:id="@+id/adminIcon"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_admin"
                app:tint="@color/white"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/admin_registration"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_below="@id/adminIcon"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/admin_reg_subtitle"
                android:textColor="@color/white"
                android:layout_below="@id/adminIcon"
                android:layout_marginTop="40dp"/>

        </RelativeLayout>

        <!-- Card Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section 1: Personal Information -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="@string/section_personal_info"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <EditText
                            android:id="@+id/etFullName"
                            android:hint="Enter full name"
                            android:background="@drawable/bg_input_field"
                            android:drawableStart="@drawable/ic_person"
                            android:drawablePadding="12dp"
                            android:padding="12dp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:inputType="textPersonName"
                            android:maxLines="1"/>



                    </LinearLayout>


                    <Spinner
                        android:id="@+id/spinnerGender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_spinner"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etContactNumber"
                        android:hint="@string/hint_contact_number"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_phone"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:inputType="phone"
                        android:maxLength="15"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etEmail"
                        android:hint="@string/hint_email_address"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_email"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:inputType="textEmailAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section 2: Admin Information -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="@string/section_admin_info"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/etAdminId"
                        android:hint="@string/hint_admin_id"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_id_card"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:focusable="false"
                        android:clickable="false"
                        android:text="ADM-XXXX-XXXX"/>

                    <Spinner
                        android:id="@+id/spinnerAdminLevel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_spinner"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etAdminRegion"
                        android:hint="@string/hint_admin_region"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_location"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section 3: Verification Information -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="@string/section_verification_info"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/etGovIdNumber"
                        android:hint="@string/hint_gov_id_number"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_id_card"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:inputType="text"
                        android:maxLines="1"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <Button
                            android:id="@+id/btnUploadIdProof"
                            android:text="@string/btn_upload_id_proof"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_button_outline"
                            android:textColor="@color/primary"
                            style="?android:attr/buttonBarButtonStyle"/>

                    </LinearLayout>


                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section 4: Account Details -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="@string/section_account_details"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/etUsername"
                        android:hint="@string/hint_username"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_person"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:inputType="text"
                        android:maxLines="1"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">

                        <EditText
                            android:id="@+id/etPassword"
                            android:hint="@string/hint_password"
                            android:background="@drawable/bg_input_field"
                            android:drawableStart="@drawable/ic_lock"
                            android:drawablePadding="12dp"
                            android:padding="12dp"
                            android:paddingEnd="48dp"
                            android:inputType="textPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                        <ImageButton
                            android:id="@+id/btnTogglePassword"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_alignEnd="@id/etPassword"
                            android:layout_centerVertical="true"
                            android:background="@android:color/transparent"
                            android:src="@drawable/ic_eye"
                            app:tint="@color/text_secondary"/>

                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">

                        <EditText
                            android:id="@+id/etConfirmPassword"
                            android:hint="@string/hint_confirm_password"
                            android:background="@drawable/bg_input_field"
                            android:drawableStart="@drawable/ic_lock"
                            android:drawablePadding="12dp"
                            android:padding="12dp"
                            android:paddingEnd="48dp"
                            android:inputType="textPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                        <ImageButton
                            android:id="@+id/btnToggleConfirmPassword"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_alignEnd="@id/etConfirmPassword"
                            android:layout_centerVertical="true"
                            android:background="@android:color/transparent"
                            android:src="@drawable/ic_eye"
                            app:tint="@color/text_secondary"/>

                    </RelativeLayout>

                    <Spinner
                        android:id="@+id/spinnerSecurityQuestion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_spinner"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etSecurityAnswer"
                        android:hint="@string/hint_security_answer"
                        android:background="@drawable/bg_input_field"
                        android:drawableStart="@drawable/ic_lock"
                        android:drawablePadding="12dp"
                        android:padding="12dp"
                        android:inputType="text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Admin Terms and Conditions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/checkboxAdminTermsConditions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary"
                    android:scaleX="1.2"
                    android:scaleY="1.2" />

                <TextView
                    android:id="@+id/tvAdminTermsConditions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="I accept the Terms and Conditions for administrators"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="normal" />

            </LinearLayout>

            <!-- Action Buttons -->
            <Button
                android:id="@+id/btnRegister"
                android:text="@string/btn_register"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_register"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnReset"
                    android:text="@string/btn_reset"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_button_outline"
                    android:textColor="@color/primary"
                    style="?android:attr/buttonBarButtonStyle"/>

                <Button
                    android:id="@+id/btnBackToLogin"
                    android:text="@string/btn_back_to_login"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_button_outline"
                    android:textColor="@color/primary"
                    style="?android:attr/buttonBarButtonStyle"/>

            </LinearLayout>

            <!-- Footer -->
            <TextView
                android:text="@string/admin_reg_footer"
                android:textSize="12sp"
                android:textColor="@color/footer_text"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
