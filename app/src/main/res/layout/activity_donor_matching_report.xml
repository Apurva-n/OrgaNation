<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="100dp"
        android:visibility="visible" />

    <!-- Recipient Info -->
    <TextView
        android:id="@+id/tvRecipientInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Finding compatible donors..."
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:textStyle="bold"
        android:gravity="center" />

    <!-- No Matches Message -->
    <TextView
        android:id="@+id/tvNoMatches"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="No compatible donors found for this recipient."
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Content Layout -->
    <LinearLayout
        android:id="@+id/llContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Donor Matches RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDonorMatches"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp" />

        <!-- Export Button -->
        <Button
            android:id="@+id/btnExportReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:text="📄 Export Matching Report"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            style="@style/Widget.AppCompat.Button.Colored" />

    </LinearLayout>

</LinearLayout>
