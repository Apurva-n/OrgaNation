<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Request Details"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/primary_color"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Request Information Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Request Information"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvRequestID"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Request ID: REQ_12345"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏳ Pending"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp" />

        <!-- Recipient Information Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recipient Information"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvRecipientName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="XYZ PQR"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvRecipientAadhaar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aadhaar: 123456789012"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <!-- Organ Information Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Organ Information"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvOrganType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kidney"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvBloodType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Blood Type: O+"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvUrgency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Urgency: High"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <!-- Hospital Information Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hospital Information"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvHospitalName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apollo Hospital"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvHospitalCity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mumbai"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvHospitalLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="123 Main Street"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvTreatingDoctor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dr. Smith"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <!-- Medical Information Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Medical Information"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvMedicalDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chronic kidney disease"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvAdditionalNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Additional notes"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvRequestDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Request Date: 31/03/2026"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp" />

        <!-- Hospital Actions Section -->
        <LinearLayout
            android:id="@+id/llHospitalActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:padding="16dp"
            android:background="@drawable/bg_input_field"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hospital Actions"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginBottom="16dp" />

            <!-- Hospital Notes -->
            <EditText
                android:id="@+id/etHospitalNotes"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="Hospital Notes"
                android:background="@drawable/bg_input_field"
                android:gravity="top"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:inputType="textMultiLine" />

            <Button
                android:id="@+id/btnSaveNotes"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Save Notes"
                android:textColor="@color/white"
                android:background="@color/primary"
                android:layout_marginBottom="16dp" />

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnApprove"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="Approve"
                    android:textColor="@color/white"
                    android:background="@color/success_green" />

                <Button
                    android:id="@+id/btnProcess"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Process"
                    android:textColor="@color/white"
                    android:background="@color/purple" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnComplete"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="Complete"
                    android:textColor="@color/white"
                    android:background="@color/accent" />

                <Button
                    android:id="@+id/btnDecline"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Decline"
                    android:textColor="@color/white"
                    android:background="@color/heart_red" />

            </LinearLayout>

        </LinearLayout>

        <!-- Status History Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status History"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvHospitalNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hospital Notes: No notes from hospital"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvApprovedDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Approved Date: Not yet approved"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvProcessedDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Processed Date: Not yet processed"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvCompletedDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Completed Date: Not yet completed"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDeclinedDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Declined Date: Not declined"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDeclinedReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Decline Reason: No decline reason"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp" />

        <!-- Decline Reason Input -->
        <EditText
            android:id="@+id/etDeclinedReason"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="Reason for declining"
            android:background="@drawable/bg_input_field"
            android:gravity="top"
            android:padding="12dp"
            android:layout_marginBottom="24dp"
            android:inputType="textMultiLine"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
