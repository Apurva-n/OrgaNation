<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Recipient Information -->
    <TextView
        android:id="@+id/tvRecipientInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Recipient Information"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" />

    <!-- Donor Selection -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Donor:"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/spinnerDonors"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_input_field"
        android:padding="12dp" />

    <!-- Transplant Date -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Transplant Date:"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etTransplantDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Select transplant date"
        android:focusable="false"
        android:clickable="true"
        android:background="@drawable/bg_input_field"
        android:padding="12dp"
        android:layout_marginBottom="16dp" />

    <!-- Transplant Time -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Transplant Time:"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etTransplantTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Select transplant time"
        android:focusable="false"
        android:clickable="true"
        android:background="@drawable/bg_input_field"
        android:padding="12dp"
        android:layout_marginBottom="24dp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="@color/text_secondary"
            android:background="@android:color/transparent"
            android:layout_marginEnd="8dp"
            style="@style/Widget.AppCompat.Button.Borderless" />

        <Button
            android:id="@+id/btnSelect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Donor"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            style="@style/Widget.AppCompat.Button.Colored" />

    </LinearLayout>

</LinearLayout>
