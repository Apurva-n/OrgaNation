<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_signup">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Beautiful Header with Logo -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="@drawable/signup_header_bg">

            <!-- Floating Heart Logo -->
            <ImageView
                android:id="@+id/logoHeart"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="40dp"
                android:src="@drawable/ic_map"
                app:tint="@color/white"/>

            <!-- Main Title -->
            <TextView
                android:id="@+id/mainTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/logoHeart"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="16dp"
                android:text="@string/signup_welcome"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:shadowColor="#80000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"/>

            <!-- Subtitle -->
            <TextView
                android:id="@+id/subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/mainTitle"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="8dp"
                android:text="@string/signup_subtitle"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:alpha="0.9"/>

            <!-- Decorative Elements -->
            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_margin="16dp"
                android:src="@drawable/ic_heart_plus"
                app:tint="@color/white"
                android:alpha="0.3"/>

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_alignParentBottom="true"
                android:layout_margin="24dp"
                android:src="@drawable/ic_medical"
                app:tint="@color/white"
                android:alpha="0.3"/>

        </RelativeLayout>

        <!-- User Type Selection Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:text="@string/select_user_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="16dp"
                android:gravity="center"/>

            <!-- User Type Cards Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <!-- Donor Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardDonor"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/card_ripple">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp"
                        android:background="@drawable/card_donor_bg">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_heart_logo"
                            app:tint="@color/primary"/>

                        <TextView
                            android:text="@string/user_donor"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginTop="8dp"
                            android:gravity="center" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Recipient Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardRecipient"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/card_ripple">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp"
                        android:background="@drawable/card_recipient_bg">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_heart_plus"
                            app:tint="@color/primary"/>

                        <TextView
                            android:text="@string/user_recipient"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginTop="8dp"
                            android:gravity="center"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <!-- Hospital Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardHospital"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/card_ripple">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp"
                        android:background="@drawable/card_hospital_bg">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_hospital"
                            app:tint="@color/primary"/>

                        <TextView
                            android:text="@string/user_hospital"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginTop="8dp"
                            android:gravity="center"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Admin Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAdmin"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/card_ripple">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp"
                        android:background="@drawable/card_admin_bg">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_admin"
                            app:tint="@color/primary"/>

                        <TextView
                            android:text="@string/user_admin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginTop="8dp"
                            android:gravity="center"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Selected User Type Display -->
            <androidx.cardview.widget.CardView
                android:id="@+id/selectedTypeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/primary_light"
                android:layout_marginBottom="20dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/selectedTypeIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:tint="@color/primary"/>

                    <TextView
                        android:id="@+id/selectedTypeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:textSize="16sp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Basic Registration Form -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:text="@string/create_account"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="20dp"
                        android:gravity="center"/>

                    <!-- Full Name -->
                    <EditText
                        android:id="@+id/UserFullName"
                        android:hint="@string/hint_full_name"
                        android:background="@drawable/bg_input_field_beautiful"
                        android:drawableStart="@drawable/ic_person"
                        android:drawablePadding="16dp"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:inputType="textPersonName"
                        android:textColorHint="@color/text_hint"/>

                    <!-- Email -->
                    <EditText
                        android:id="@+id/UserEmail"
                        android:hint="@string/hint_email"
                        android:background="@drawable/bg_input_field_beautiful"
                        android:drawableStart="@drawable/ic_email_beautiful"
                        android:drawablePadding="16dp"
                        android:padding="16dp"
                        android:inputType="textEmailAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:textColorHint="@color/text_hint"/>

                    <!-- Phone -->
                    <EditText
                        android:id="@+id/UserPhone"
                        android:hint="@string/hint_phone"
                        android:background="@drawable/bg_input_field_beautiful"
                        android:drawableStart="@drawable/ic_phone_beautiful"
                        android:drawablePadding="16dp"
                        android:padding="16dp"
                        android:inputType="phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:textColorHint="@color/text_hint"/>

                    <!-- Password -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp">

                        <EditText
                            android:id="@+id/etPassword"
                            android:hint="@string/hint_password"
                            android:background="@drawable/bg_input_field_beautiful"
                            android:drawableStart="@drawable/ic_lock_beautiful"
                            android:drawablePadding="16dp"
                            android:padding="16dp"
                            android:paddingEnd="56dp"
                            android:inputType="textPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColorHint="@color/text_hint"/>

                        <ImageButton
                            android:id="@+id/btnTogglePassword"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_alignEnd="@id/etPassword"
                            android:layout_centerVertical="true"
                            android:background="@android:color/transparent"
                            android:src="@drawable/ic_eye_beautiful"
                            app:tint="@color/text_secondary"/>

                    </RelativeLayout>

                    <!-- Re enter password -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp">

                        <EditText
                            android:id="@+id/etPassword1"
                            android:hint="@string/hint_password"
                            android:background="@drawable/bg_input_field_beautiful"
                            android:drawableStart="@drawable/ic_lock_beautiful"
                            android:drawablePadding="16dp"
                            android:padding="16dp"
                            android:paddingEnd="56dp"
                            android:inputType="textPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColorHint="@color/text_hint"/>

                        <ImageButton
                            android:id="@+id/btnTogglePassword1"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_alignEnd="@id/etPassword1"
                            android:layout_centerVertical="true"
                            android:background="@android:color/transparent"
                            android:src="@drawable/ic_eye_beautiful"
                            app:tint="@color/text_secondary"/>

                    </RelativeLayout>


                    <!-- Terms and Conditions -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="24dp"
                        android:gravity="center_vertical">

                        <CheckBox
                            android:id="@+id/checkboxTerms"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/tvTermsConditions"
                            android:text="@string/terms_agreement"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                    </LinearLayout>

                    <!-- Sign Up Button -->
                    <Button
                        android:id="@+id/btnSignUp"
                        android:text="@string/btn_sign_up"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_button_signup_beautiful"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"
                        android:elevation="4dp"/>

                    <!-- Already have account -->
                    <TextView
                        android:id="@+id/tvLoginLink"
                        android:text="@string/already_have_account"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Social Login Options -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:text="@string/or_sign_up_with"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- Google Sign In -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardGoogleSignIn"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="16dp"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/card_ripple">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_google"
                           />

                    </androidx.cardview.widget.CardView>

                    <!-- Facebook Sign In -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardFacebookSignIn"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginStart="16dp"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/card_ripple">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_facebook"
                            />

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
