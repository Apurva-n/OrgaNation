<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_gradient_start">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/gradient_header"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💚 Find Your Lifesaver 💚"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_on_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Browse heroes who can make a difference"
                android:textSize="14sp"
                android:textColor="@color/accent"
                android:textAlignment="center" />

        </LinearLayout>

        <!-- Inspirational Quote -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="&quot;One organ donation can save up to 8 lives. Be someone's hero.&quot;"
            android:textSize="13sp"
            android:textStyle="italic"
            android:textColor="@color/text_secondary"
            android:textAlignment="center"
            android:padding="16dp"
            android:background="@color/bg_input"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="12dp" />

        <!-- RecyclerView for Donors -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDonors"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:clipToPadding="false" />

    </LinearLayout>

    <!-- Floating Filter Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabFilter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="Filter donors"
        app:srcCompat="@drawable/ic_filter_list"
        app:backgroundTint="@color/primary"
        app:tint="@color/white" />

</FrameLayout>
