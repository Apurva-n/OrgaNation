<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    
    <!-- Glow Ring - Outer Ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:pathData="M100,20 A80,80 0 1,1 100,180 A80,80 0 1,1 100,20 Z"/>
    
    <!-- Inner Ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:pathData="M100,35 A65,65 0 1,1 100,165 A65,65 0 1,1 100,35 Z"/>
    
    <!-- Decorative Dots -->
    <circle
        android:fillColor="#FFFFFF"
        android:centerX="100"
        android:centerY="20"
        android:radius="4dp"/>
    
    <circle
        android:fillColor="#FFFFFF"
        android:centerX="180"
        android:centerY="100"
        android:radius="4dp"/>
    
    <circle
        android:fillColor="#FFFFFF"
        android:centerX="100"
        android:centerY="180"
        android:radius="4dp"/>
    
    <circle
        android:fillColor="#FFFFFF"
        android:centerX="20"
        android:centerY="100"
        android:radius="4dp"/>
    
</vector>
